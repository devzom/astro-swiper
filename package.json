{
  "name": "astro-swiper",
  "version": "2.5.0",
  "description": "Astro component for swiper, dedicated to slider / carousel / photo swiper / slide, including thumbnails",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "format": "biome format --write && prettier -w \"**/*.astro\"",
    "lint": "biome lint",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pascal-brand38/astro-swiper.git"
  },
  "author": "Pascal Brand",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pascal-brand38/astro-swiper/issues"
  },
  "homepage": "https://pascal-brand38.github.io/astro-dev/packages/astro-swiper/",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    }
  },
  "files": [
    "index.ts",
    "src/**"
  ],
  "engines": {
    "pnpm": ">=10.30.3",
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^24.12.0",
    "astro": "^5.18.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "swiper",
    "withastro",
    "astro-component",
    "image",
    "carousel",
    "swiper",
    "slider",
    "slideshow",
    "gallery",
    "lightweight",
    "touch",
    "responsive",
    "thumbnail"
  ],
  "dependencies": {
    "swiper": "^12.1.3"
  }
}
